# ==========================================
# 1. DỮ LIỆU DỰ ÁN (PROJECT DATA)
# ==========================================
# Bỏ qua toàn bộ dữ liệu thô (rất nặng) nhưng giữ lại file .gitkeep để giữ cấu trúc thư mục
data/raw/*
!data/raw/.gitkeep

# Tùy chọn: Nếu file đồ thị GraphML/GEXF quá lớn (>100MB), hãy bỏ comment các dòng dưới đây
# data/processed/*.gexf
# data/processed/*.graphml
# data/processed/*.csv

# ==========================================
# 2. MÔI TRƯỜNG PYTHON (PYTHON ENVIRONMENTS)
# ==========================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# C-extensions
*.so

# Thư mục môi trường ảo (Virtual Environments)
venv/
.venv/
env/
.env/
ENV/

# File chứa biến môi trường (Bảo mật)
.env
.env.local
.env.*

# Thư viện tải về và cache của hệ thống
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.log

# ==========================================
# 3. JUPYTER NOTEBOOK & DATA SCIENCE TOOLS
# ==========================================
.ipynb_checkpoints/
profile_default/
ipython_config.py

# ==========================================
# 4. HỆ ĐIỀU HÀNH & PHẦN MỀM CHỈNH SỬA (OS & IDE)
# ==========================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
$RECYCLE.BIN/

# VSCode (Visual Studio Code)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# PyCharm / IntelliJ (JetBrains)
.idea/
*.iws
*.iml
*.ipr